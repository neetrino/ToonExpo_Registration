# Application
SITE_URL="http://localhost:3000"

# Neon PostgreSQL
# Pooled, least-privilege application connection used at runtime.
DATABASE_URL="postgresql://app_user:password@host-pooler/database?sslmode=require"
# Direct migration connection; do not expose it to the deployed runtime.
DIRECT_URL="postgresql://migration_user:password@host/database?sslmode=require"

# Auth.js
AUTH_SECRET="replace-with-a-generated-high-entropy-secret"

# Resend
RESEND_API_KEY="re_replace_with_resend_api_key"
EMAIL_FROM="Toon Expo <registration@example.com>"
